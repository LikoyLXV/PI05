#include <iostream>
#include <string>
using namespace std;

class Shooting {
protected:
    string name;
    int shots;

public:
    Shooting(string n, int s) {
        name = n;
        shots = s;
    }

    virtual void info() {
        cout << "Участник: " << name << endl;
        cout << "Выстрелов: " << shots << endl;
    }

    virtual ~Shooting() {}
};

class Pistol : public Shooting {
public:
    Pistol(string n, int s) : Shooting(n, s) {}

    void info() override {
        cout << "Стрельба из пистолета" << endl;
        cout << "Участник: " << name << endl;
        cout << "Выстрелов: " << shots << endl;
    }
};

class Rifle : public Shooting {
public:
    Rifle(string n, int s) : Shooting(n, s) {}

    void info() override {
        cout << "Стрельба из винтовки" << endl;
        cout << "Участник: " << name << endl;
        cout << "Выстрелов: " << shots << endl;
    }
};

int main() {
    setlocale(LC_ALL, "Russian");

    Shooting* a;
    Shooting* b;

    a = new Pistol("Иван", 10);
    b = new Rifle("Петр", 15);

    a->info();
    cout << "-------------------" << endl;
    b->info();

    delete a;
    delete b;

    return 0;
}
